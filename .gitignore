# macOS/Windows generated files
.DS_Store
Thumbs.db

# IDE settings
.vscode/*
!.vscode/extensions.json
.idea/
.vs/

# Log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables - Contains sensitive data
.env
.env.local
.env.*.local
!*.env.example

